{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "reelity",
  "compatibility_date": "2026-06-18",
  "main": "./worker/index.ts",
  "vars": {
    "BRAIN_PROVIDER": "anthropic",
    "ASSETS_BASE_URL": "https://assets.reelity.arjunkrishna.dev"
  },
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/v/*", "/ffmpeg/*"]
  },
  "ai": {
    "binding": "AI"
  },
  "r2_buckets": [
    {
      "binding": "VIDEOS",
      "bucket_name": "reelity-videos"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "reelity",
      "database_id": "6634ddf3-af62-49f8-ae96-c0a1df8f608a"
    }
  ],
  "ratelimits": [
    {
      "name": "CHAT_RL",
      "namespace_id": "1001",
      "simple": { "limit": 10, "period": 60 }
    },
    {
      "name": "ASSET_RL",
      "namespace_id": "1002",
      "simple": { "limit": 120, "period": 60 }
    }
  ],
  "observability": {
    "enabled": true
  }
}
