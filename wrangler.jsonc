{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "reelity",
  "compatibility_date": "2026-06-18",
  "main": "./worker/index.ts",
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/v/*"]
  },
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  }
}
